meta {
  name: Metrics - verify chunked_prefill technique
  type: http
  seq: 6
}

get {
  url: {{metrics_url}}/metrics
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("chunked_prefill technique label appears in metrics", function() {
    expect(res.body).to.include('technique="chunked_prefill"');
  });
}
