meta {
  name: Invalid stream type
  type: http
  seq: 10
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: inherit
}

body:json {
  {
    "model": "local",
    "messages": [{"role": "user", "content": "hello"}],
    "stream": "yes"
  }
}

tests {
  test("status is 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error is invalid_stream", function() {
    expect(res.body.error).to.equal("invalid_stream");
  });
}
