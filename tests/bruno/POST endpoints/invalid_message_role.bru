meta {
  name: Invalid message role
  type: http
  seq: 13
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: inherit
}

body:json {
  {
    "model": "local",
    "messages": [{"role": "bot", "content": "hello"}]
  }
}

tests {
  test("status is 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error is invalid_messages", function() {
    expect(res.body.error).to.equal("invalid_messages");
  });
}
