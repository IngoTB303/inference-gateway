meta {
  name: Default backend fallback
  type: http
  seq: 15
}

docs {
  Omitting "model" from the request should route to default_backend (local echo).
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: inherit
}

body:json {
  {
    "messages": [{"role": "user", "content": "hello"}]
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("backend field is present", function() {
    expect(res.body).to.have.property("backend");
  });

  test("id field is present", function() {
    expect(res.body).to.have.property("id");
  });
}
