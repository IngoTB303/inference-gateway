meta {
  name: Invalid temperature
  type: http
  seq: 12
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: inherit
}

body:json {
  {
    "model": "local",
    "messages": [{"role": "user", "content": "hello"}],
    "temperature": 5.0
  }
}

tests {
  test("status is 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error is invalid_temperature", function() {
    expect(res.body.error).to.equal("invalid_temperature");
  });
}
