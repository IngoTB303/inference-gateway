meta {
  name: Real Backend - local-llama
  type: http
  seq: 16
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: inherit
}

body:json {
  {
    "model": "local-llama",
    "messages": [{"role": "user", "content": "Hi, what is your key advantage?"}],
    "max_tokens": 1024
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("backend field is 'local-llama'", function() {
    expect(res.body.backend).to.equal("local-llama");
  });
  
  test("choices has at least one entry", function() {
    expect(res.body.choices).to.have.length.above(0);
  });
  
  test("usage.latency_ms is present and non-negative", function() {
    expect(res.body.usage).to.have.property("latency_ms");
    expect(res.body.usage.latency_ms).to.be.at.least(0);
  });
}

docs {
  Routes to the local llama.cpp backend (http://localhost:8081).
  Requires a running llama.cpp server on port 8081.
}
