meta {
  name: Backend Success (echo)
  type: http
  seq: 1
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: inherit
}

body:json {
  {
    "model": "local",
    "messages": [{"role": "user", "content": "Hello world!"}]
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("id field is present", function() {
    expect(res.body).to.have.property("id");
  });
  
  test("backend field is 'local'", function() {
    expect(res.body.backend).to.equal("local");
  });
  
  test("X-Request-ID response header is present", function() {
    expect(res.headers).to.have.property("x-request-id");
  });
}

docs {
  Routes to the local echo backend. No live backend required.
  The "backend" field in the response should be "local".
}
