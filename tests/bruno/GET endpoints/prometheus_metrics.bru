meta {
  name: Prometheus Metrics (:9101)
  type: http
  seq: 7
}

get {
  url: {{metrics_url}}/metrics
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("content-type is Prometheus text format", function() {
    expect(res.headers["content-type"]).to.include("text/plain");
  });

  test("gateway_requests_total metric is defined", function() {
    expect(res.body).to.include("gateway_requests_total");
  });

  test("gateway_active_requests metric is defined", function() {
    expect(res.body).to.include("gateway_active_requests");
  });

  // Note: technique= and server_profile= label values only appear after at least
  // one request has been processed. Run the Metrics folder tests (which fire a
  // request first) to assert label presence.
}
