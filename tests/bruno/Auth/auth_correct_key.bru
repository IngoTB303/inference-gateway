meta {
  name: Auth - correct key (200)
  type: http
  seq: 2
}

docs {
  Requires the gateway to be running with API_KEY=test-key in .env.
  Sends the correct Bearer token and expects a 200 response.
}

post {
  url: {{base_url}}/v1/chat/completions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{api_key}}
}

body:json {
  {
    "model": "local",
    "messages": [{"role": "user", "content": "hello"}]
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
}
