    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Backend-only latency (excludes gateway auth/validation/normalisation overhead). Compare with E2E on the right to isolate where time is spent.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, backend, technique) (rate(gateway_backend_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 backend {{backend}} / {{technique}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, backend, technique) (rate(gateway_backend_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 backend {{backend}} / {{technique}}",
          "refId": "B"
        }
      ],
      "title": "Backend-only latency (gateway_backend_request_duration_seconds)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Mean E2E vs mean backend-only latency overlaid. The gap between the two lines is gateway overhead (validation, auth, response normalisation).",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (technique, server_profile) (rate(gateway_request_duration_seconds_sum[5m])) / sum by (technique, server_profile) (rate(gateway_request_duration_seconds_count[5m]))",
          "legendFormat": "E2E mean {{technique}}/{{server_profile}}",
          "refId": "A"
        },
        {
          "expr": "sum by (backend, technique) (rate(gateway_backend_request_duration_seconds_sum[5m])) / sum by (backend, technique) (rate(gateway_backend_request_duration_seconds_count[5m]))",
          "legendFormat": "backend mean {{backend}}/{{technique}}",
          "refId": "B"
        }
      ],
      "title": "E2E vs backend mean latency (gap = gateway overhead)",
      "type": "timeseries"
    },
    {
      "datasource": {
