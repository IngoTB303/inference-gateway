# Inference Gateway backend configuration
#
# Copy this file to config.yaml and edit to match your setup.
#
# Each backend entry needs at minimum: name, type
# HTTP backends also need: url
# Optional per-backend: timeout (seconds, default 60)
#                        model  — forwarded as "model" in the request body;
#                                 required for servers that validate this field
#                                 (e.g. vLLM).  Omit for llama.cpp.
#
# Route requests by setting "model" in the request body to a backend name.
# Requests with no "model" or an unrecognized name fall back to default_backend.

backends:
  - name: local
    type: echo

  - name: local-llama
    type: http
    url: http://localhost:8081
    timeout: 60

  - name: remote-modal-llama
    type: http
    url: https://your-modal-username--relay-llama-server-web.modal.run/
    timeout: 60

  - name: remote-modal-vllm
    type: http
    url: https://your-modal-username--relay-vllm-server-web.modal.run/
    timeout: 120
    model: default   # vLLM requires this field; any string is accepted

  # Gemma 4 A/B experiment backends — URLs printed by deploy_modal_vllm.sh
  - name: modal-gemma4-standard
    type: http
    url: https://your-modal-username--vllm-gemma4-standard-serve.modal.run/
    timeout: 120
    model: gemma-4-e2b-it

  - name: modal-gemma4-optimized
    type: http
    url: https://your-modal-username--vllm-gemma4-optimized-serve.modal.run/
    timeout: 120
    model: gemma-4-e2b-it

  - name: modal-gemma4-hardcore
    type: http
    url: https://your-modal-username--vllm-gemma4-hardcore-serve.modal.run/
    timeout: 120
    model: gemma-4-e2b-it  # 8192-token batches, 256 seqs, 95% GPU util

default_backend: local
